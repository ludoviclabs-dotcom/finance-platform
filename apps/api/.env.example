# CarbonCo API — copier vers .env (ou définir sur Vercel « carbonco-api »).
# Sans DATABASE_URL, l'API tourne en mode dégradé /tmp JSON (utile en dev/CI).

# ── Serveur ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Base de données (Neon) ──────────────────────────────────────────────────
# URL POOLÉE pour l'API (pgbouncer) :
DATABASE_URL=
# URL DIRECTE pour le worker (LISTEN/NOTIFY — ne passe pas par le pooler) :
DATABASE_URL_DIRECT=
# Réservée PR-02C (workflow db-migrate.yml, non créé en PR-02B) : connexion
# NON poolée dédiée au runner de migrations (PgBouncer en mode transaction
# casse les advisory locks de session, cf. 009_rls_force.sql). PR-02B utilise
# DATABASE_URL/DATABASE_URL_DIRECT selon les patterns existants — pas
# obligatoire tant que le workflow protégé n'existe pas (D-4).
DATABASE_ADMIN_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-en-prod
# TOTP (2FA) : clé Fernet base64 32 octets —
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# ── Réseau / sécurité ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# 1 pour désactiver le rate limit (tests d'intégration) :
RATE_LIMIT_DISABLED=
# RLS FORCE (migration 009) : 1 pour activer (APRÈS validation Neon). Défaut OFF.
RLS_FORCE=0

# ── Ingestion asynchrone (T1.3) ─────────────────────────────────────────────
# inline (défaut) | worker
WORKER_MODE=inline

# ── Stockage objet (T1.6) ───────────────────────────────────────────────────
# local (défaut) | vercel-blob
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=.data/storage
BLOB_READ_WRITE_TOKEN=
# Secret de signature des URL locales (HMAC) :
SIGNED_URL_SECRET=change-me

# ── E-mails (T5.3 — OPTIONNEL, SMTP stdlib, aucune dépendance payante) ──────
# Sans EMAIL_ENABLED, tout reste in-app (notifications) — zéro dépendance.
EMAIL_ENABLED=
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Tâches quotidiennes (T7.2 / T7.3) ───────────────────────────────────────
# Jeton partagé avec le cron Vercel (apps/carbon /api/cron/evaluate-alerts) :
# les endpoints /beges/reminders/run et /suppliers/campaigns/reminders/run
# acceptent ce Bearer OU un JWT analyst. Générer une valeur aléatoire longue.
CRON_SERVICE_TOKEN=
# Destinataire (optionnel) des rappels d'échéance BEGES par e-mail :
BEGES_REMINDER_EMAIL=
# Destinataire (optionnel) des candidatures partenaires (T7.5) :
PARTNER_NOTIFY_EMAIL=
# Base des liens publics générés (questionnaires fournisseurs /q/{token}) :
FRONTEND_URL=https://carbon-snowy-nine.vercel.app

# ── Observabilité (T1.7) ────────────────────────────────────────────────────
# Optionnel — no-op si absent :
SENTRY_DSN=
