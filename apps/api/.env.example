# CarbonCo API — copier vers .env (ou définir sur Vercel « carbonco-api »).
# Sans DATABASE_URL, l'API tourne en mode dégradé /tmp JSON (utile en dev/CI).

# ── Serveur ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Base de données (Neon) ──────────────────────────────────────────────────
# URL POOLÉE pour l'API (pgbouncer) :
DATABASE_URL=
# URL DIRECTE pour le worker (LISTEN/NOTIFY — ne passe pas par le pooler) :
DATABASE_URL_DIRECT=

# ── Auth ────────────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-en-prod
# TOTP (2FA) : clé Fernet base64 32 octets —
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# ── Réseau / sécurité ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# 1 pour désactiver le rate limit (tests d'intégration) :
RATE_LIMIT_DISABLED=
# RLS FORCE (migration 009) : 1 pour activer (APRÈS validation Neon). Défaut OFF.
RLS_FORCE=0

# ── Ingestion asynchrone (T1.3) ─────────────────────────────────────────────
# inline (défaut) | worker
WORKER_MODE=inline

# ── Stockage objet (T1.6) ───────────────────────────────────────────────────
# local (défaut) | vercel-blob
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=.data/storage
BLOB_READ_WRITE_TOKEN=
# Secret de signature des URL locales (HMAC) :
SIGNED_URL_SECRET=change-me

# ── Observabilité (T1.7) ────────────────────────────────────────────────────
# Optionnel — no-op si absent :
SENTRY_DSN=
