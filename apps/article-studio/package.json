    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "postinstall": "prisma generate",
    "seed:corpus": "tsx --env-file-if-exists=.env.local scripts/seed-corpus.ts",
    "eval:rag": "tsx --env-file-if-exists=.env.local scripts/eval-rag.ts",
    "e2e:smoke": "tsx --env-file-if-exists=.env.local scripts/e2e-smoke.ts"
  },
