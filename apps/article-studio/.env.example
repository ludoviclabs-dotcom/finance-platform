# ─────────────────────────────────────────────────────────────
# ARTICLE STUDIO — env template
# Copy this file to `.env.local` and fill the values you need.
# All keys are optional at build time; features gracefully degrade.
# ─────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# ── Database (Neon — dedicated to article-studio, pgvector enabled) ──
DATABASE_URL=
DIRECT_URL=

# ── Redis (Upstash — rate limiting) ─────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI — Vercel AI Gateway (preferred) ──────────────────────
AI_GATEWAY_API_KEY=
# Local-dev direct Anthropic key
ANTHROPIC_API_KEY=

# ── Embeddings (primary: Voyage; fallback: OpenAI) ──────────
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ── Reranker (optional — Cohere multilingual) ───────────────
COHERE_API_KEY=

# ── Observability (Langfuse) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Security (Lakera input guard) ───────────────────────────
LAKERA_API_KEY=

# ── File storage (Vercel Blob) ──────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Auth (single-tenant studio — optional bearer token) ─────
INTERNAL_REVIEW_TOKEN=
