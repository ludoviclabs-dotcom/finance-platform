# Carbon app — npm configuration.
#
# legacy-peer-deps=true contournes un conflit de peerOptional dans le monorepo :
# @vercel/analytics >= 1.6 déclare un peer optional sur @sveltejs/kit (utilisé
# par d'autres apps du repo) qui pousse vite 8, en conflit avec vite 7 requis
# par vitest. L'application Carbon n'utilise pas Svelte — ce peer est ignoré
# en sécurité.
#
# À retirer dès que @vercel/analytics ne déclare plus ce peer ou que le repo
# n'utilise plus Svelte.
legacy-peer-deps=true
