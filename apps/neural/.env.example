# ─────────────────────────────────────────────────────────────
# NEURAL — env template
# Copy this file to `.env.local` and fill the values you need.
# All keys are optional at build time; features gracefully degrade.
# ─────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (Neon — Vercel Marketplace) ────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Redis (Upstash — Vercel Marketplace or direct) ──────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI — Vercel AI Gateway (preferred) ──────────────────────
AI_GATEWAY_API_KEY=
# Legacy direct Anthropic key (still used by /api/chat-demo)
ANTHROPIC_API_KEY=

# ── Observability (Langfuse) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Eval (Braintrust) ───────────────────────────────────────
BRAINTRUST_API_KEY=

# ── Security (Lakera input guard) ───────────────────────────
LAKERA_API_KEY=

# ── Email (Resend) — contact form ───────────────────────────
RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@neural.fr
CONTACT_TO_EMAIL=ludoviclabs@gmail.com

# ── Feature flags ───────────────────────────────────────────
# All OFF by default in production. Flip to "1" locally to preview
# work-in-progress sections without shipping them publicly.
NEXT_PUBLIC_FEATURE_MARKETPLACE=0
NEXT_PUBLIC_FEATURE_FORFAITS=0
NEXT_PUBLIC_FEATURE_RESOURCES=0
NEXT_PUBLIC_FEATURE_RH_LUXE=0
