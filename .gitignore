.venv/

# Debug / temp scripts
debug-*.ts
test-debug*.ts
test-*-parser.ts
test-parser.ts

# Generated data files (keep templates, not outputs)
*.xlsx
# Exception: Carbon master workbooks shipped with the API
!apps/api/data/*.xlsx

# Screenshots / media not part of the app
*.png
!apps/*/public/**/*.png
!apps/*/app/**/*.png
*.mp4
!apps/*/public/**/*.mp4
# Screenshots JPEGs — same rule as PNG (ignored at repo root, allowed under app assets)
*.jpeg
*.jpg
!apps/*/public/**/*.jpeg
!apps/*/public/**/*.jpg
!apps/*/app/**/*.jpeg
!apps/*/app/**/*.jpg

# Claude Code worktrees
.claude/worktrees/

# Backup dirs
*.bak/
backups/

# Runtime logs / test artifacts
apps/*/logs/
apps/*/test-results/

# Claude Code local settings (per-machine, per-user)
.claude/settings.local.json
