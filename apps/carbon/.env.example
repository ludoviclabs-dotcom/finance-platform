# Carbon app — copy this to .env.local and fill in values
# See: https://vercel.com/docs/environment-variables

# FastAPI backend URL
# Local:      http://localhost:8000
# Production: https://your-api-domain.com  (set via Vercel Dashboard or `vercel env add`)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# URL canonique du site (SEO, sitemap, OG). Sans slash final.
# Prod actuelle (tant que D3 non actée) : https://carbon-snowy-nine.vercel.app
NEXT_PUBLIC_SITE_URL=

# Email de contact public (projet non commercialisé — D2)
NEXT_PUBLIC_CONTACT_EMAIL=ludoviclabs@gmail.com

# Observabilité front (T1.7) — optionnel ; no-op si absent
NEXT_PUBLIC_SENTRY_DSN=
