generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7+).
  // See https://pris.ly/d/config-datasource
}

// ==========================================
// AUTH
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CLIENT)

  accounts       Account[]
  sessions       Session[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  // Sprint 0 — agent runtime relations
  agentRuns AgentRun[]
  approvals Approval[] @relation("ApprovalReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  CONSULTANT
  CLIENT
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// BUSINESS
// ==========================================

model Organization {
  id      String  @id @default(cuid())
  name    String
  sector  Sector
  size    OrgSize
  revenue String?
  website String?

  users     User[]
  contracts Contract[]
  agents    DeployedAgent[]
  leads     Lead[]

  // Sprint 0 — agent runtime relations
  agentRuns AgentRun[]
  memories  Memory[]

  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Sector {
  TRANSPORT
  LUXE
  AERONAUTIQUE
  SAAS
  BANQUE
  ASSURANCE
  OTHER
}

enum OrgSize {
  SOLO
  PME
  ETI
  GRAND_GROUPE
  ENTERPRISE
}

model Contract {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  forfait       Forfait
  status        ContractStatus
  startDate     DateTime
  endDate       DateTime?
  monthlyAmount Float
  setupAmount   Float

  branches Branch[]
  agents   DeployedAgent[]
  invoices Invoice[]

  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Forfait {
  STARTER
  BUSINESS
  ENTERPRISE
  PREMIUM
  HIGH_VALUE
  POC
}

enum ContractStatus {
  DRAFT
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum Branch {
  SI
  RH
  MARKETING
  COMMUNICATION
  COMPTABILITE
  FINANCE
  SUPPLY_CHAIN
}

model DeployedAgent {
  id          String  @id @default(cuid())
  name        String
  description String?
  branch      Branch
  sector      Sector

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  contractId     String
  contract       Contract     @relation(fields: [contractId], references: [id])

  status AgentStatus

  totalQueries      Int    @default(0)
  totalTokens       BigInt @default(0)
  avgResponseTime   Float?
  satisfactionScore Float?

  config Json?

  deployedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum AgentStatus {
  DEVELOPMENT
  TESTING
  DEPLOYED
  PAUSED
  RETIRED
}

model Invoice {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  amount Float
  status InvoiceStatus
  period String

  stripeInvoiceId String?   @unique
  paidAt          DateTime?

  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ==========================================
// CRM / LEADS
// ==========================================

model Lead {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  jobTitle  String?
  company   String

  sector         Sector?
  orgSize        OrgSize?
  branches       Branch[]
  estimatedUsers Int?
  budget         String?

  status LeadStatus @default(NEW)
  source LeadSource
  score  Int        @default(0)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  notes LeadNote[]

  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE_FORM
  WEBSITE_CHAT
  WEBSITE_SIMULATOR
  WEBSITE_AUDIT_QUIZ
  LINKEDIN
  REFERRAL
  EVENT
  COLD_OUTBOUND
  PARTNER
  OTHER
}

model LeadNote {
  id      String @id @default(cuid())
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id])
  content String
  author  String

  createdAt DateTime @default(now())
}

// ==========================================
// CONTENT
// ==========================================

model NewsletterSubscriber {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String?
  sector    Sector?

  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
}

model AuditQuizResult {
  id      String  @id @default(cuid())
  email   String
  company String
  sector  Sector?

  dataMaturity    Int
  techMaturity    Int
  cultureMaturity Int
  processMaturity Int
  overallScore    Int

  recommendedForfait  Forfait?
  recommendedBranches Branch[]

  answers Json

  createdAt DateTime @default(now())
}

// ==========================================
// AGENT RUNTIME — Sprint 0 foundations
// Added 2026-04-18. Feeds:
//   • Épic 2 observability (Langfuse sync)
//   • Épic 4 explainability trace (AgentDecision graph)
//   • Épic 5 HITL (Approval queue)
//   • Épic 7 regulatory watch (RegulatoryAlert)
// ==========================================

/// One execution of an agent for a given question. Parent row for the
/// explainability trace (AgentDecision[]) and any HITL approvals.
model AgentRun {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])

  // agentId = slug stable. Ex : "ifrs9-ecl", "tva-transport", ou pour la branche
  // LUXE/Communication : "maison-voice-guard", "luxe-press-agent",
  // "luxe-event-comms", "heritage-comms", "green-claim-checker".
  // Pour Luxe Comms, le champ `trace` respecte le type LuxeCommRunTrace
  // defini dans lib/data/luxe-comms-catalog.ts.
  agentId    String
  question   String    @db.Text
  answer     String?   @db.Text
  confidence Float? // 0..1 — drives HITL routing
  status     RunStatus @default(RUNNING)
  model      String? // "anthropic/claude-sonnet-4-6" etc.
  costUsd    Decimal?  @db.Decimal(10, 6)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  /// Full ExplanationTrace (sources, steps, rules applied, uncertainties).
  trace Json?

  decisions AgentDecision[]
  approvals Approval[]

  @@index([agentId])
  @@index([organizationId, startedAt])
  @@index([status])
}

enum RunStatus {
  RUNNING
  WAITING_APPROVAL
  DONE
  FAILED
  REJECTED
}

/// Atomic step inside an AgentRun. Multiple decisions compose the trace graph
/// rendered by components/explainability/trace-view.tsx.
model AgentDecision {
  id         String       @id @default(cuid())
  runId      String
  run        AgentRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  orderIndex Int // deterministic rendering order
  kind       DecisionKind
  input      Json
  output     Json
  sources    Json // Source[] — Excel cell refs, BOFiP §, IFRS para, URLs
  durationMs Int

  createdAt DateTime @default(now())

  @@index([runId, orderIndex])
}

enum DecisionKind {
  RETRIEVE
  COMPUTE
  REASON
  VALIDATE
}

/// Long-term memory layer (Mem0-backed). Scoped by ORG, USER, or AGENT.
/// embedding is populated when pgvector is enabled in Neon.
model Memory {
  id        String      @id @default(cuid())
  scope     MemoryScope
  scopeId   String // organizationId / userId / agentId depending on scope
  key       String // semantic key, e.g. "chart-of-accounts"
  value     Json // structured payload validated by lib/memory/schemas.ts
  embedding Bytes? // vector(1536) — cast at query time until pgvector is migrated

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, scopeId])
  @@index([key])
}

enum MemoryScope {
  ORG
  USER
  AGENT
}

/// HITL queue row. Produced by AgentRun when confidence < threshold; consumed
/// by app/(dashboard)/approvals/*. Timeout → EXPIRED, never auto-approved.
model Approval {
  id     String         @id @default(cuid())
  runId  String
  run    AgentRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  tier   ApprovalTier
  status ApprovalStatus @default(PENDING)

  reviewerId String?
  reviewer   User?     @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
  reviewedAt DateTime?
  reason     String?   @db.Text

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([status, expiresAt])
  @@index([runId])
}

enum ApprovalTier {
  USER // simple click approval by the requesting user
  SUPERVISOR // escalation to a manager / controller
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Sidecar for the ambient regulatory watch (Sprint 7).
/// One row per distinct regulatory publication, with classification + impact.
model RegulatoryAlert {
  id          String   @id @default(cuid())
  source      String // "eur-lex" | "bofip" | "eba" | "anc" | "acpr" | "ifrs-foundation"
  externalId  String   @unique
  publishedAt DateTime
  title       String   @db.Text
  url         String

  /// 0..1 — >0.5 triggers notifications.
  impactScore    Float
  /// Agent IDs impacted by this publication.
  affectedAgents String[]
  /// Short summary produced by the Haiku classifier.
  summary        String   @db.Text
  /// Optional deep analysis produced by the Sonnet impact-analyzer.
  fullAnalysis   Json?

  createdAt DateTime @default(now())

  @@index([source, publishedAt])
  @@index([impactScore])
}
